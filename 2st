```html
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>AI 음성 회의록</title>

<style>

/* 기존과 유사하지만 UI를 더 정리하고 버튼 스타일을 구분함 */
body{
font-family: Arial;
background:#f2f4f7;
padding:40px;
}

.container{
max-width:800px;
margin:auto;
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 10px 20px rgba(0,0,0,0.1);
}

h1{
text-align:center;
}

/* 버튼을 기능별로 구분하기 위해 class 추가 */
button{
padding:12px 20px;
font-size:16px;
margin:10px 5px;
border:none;
border-radius:5px;
cursor:pointer;
}

/* 🎤 녹음 시작 버튼 스타일 (새로 추가된 기능) */
.start{
background:#28a745;
color:white;
}

/* ⏹ 녹음 중지 버튼 스타일 (새로 추가된 기능) */
.stop{
background:#dc3545;
color:white;
}

/* 📌 요약 버튼 (기존 기능 유지) */
.summary{
background:#007bff;
color:white;
}

/* 기존 textarea 유지하지만 역할이 바뀜 (입력 → 음성 결과 출력) */
textarea{
width:100%;
height:150px;
margin-top:15px;
padding:10px;
font-size:14px;
}

.result{
margin-top:20px;
background:#f1f3f5;
padding:20px;
border-radius:8px;
}

.timer{
text-align:center;
margin-top:10px;
color:#888;
}

</style>
</head>

<body>

<div class="container">

<h1>🤖 AI 음성 회의록</h1>

<!-- 기존: 텍스트 입력 설명 -->
<!-- 변경: 음성 입력 기반으로 설명 변경 -->
<p>마이크로 회의 내용을 말하면 자동으로 기록됩니다.</p>

<!-- 🎤 [추가] 음성 녹음 시작 버튼 -->
<button class="start" onclick="startRecording()">🎤 녹음 시작</button>

<!-- ⏹ [추가] 녹음 중지 버튼 -->
<button class="stop" onclick="stopRecording()">⏹ 녹음 중지</button>

<!-- 📌 기존 요약 기능 유지 (함수명만 변경됨: summarize → makeSummary) -->
<button class="summary" onclick="makeSummary()">📌 회의 요약</button>

<!-- 🔥 기존 meetingText → transcript로 변경 -->
<!-- 이유: 직접 입력이 아니라 음성 인식 결과가 들어가는 영역 -->
<textarea id="transcript" placeholder="음성 인식 결과가 여기에 표시됩니다..."></textarea>

<div class="result" id="summaryResult">
요약 결과가 여기에 표시됩니다.
</div>

<div class="timer">
이 웹페이지 제작 시간 ⏱ 15분 (AI와 함께 제작)
</div>

</div>

<script>

/* ============================= */
/* 🎤 [핵심 추가] 음성 인식 기능 */
/* ============================= */

// 음성 인식 객체 선언
let recognition;

/*
브라우저가 음성 인식을 지원하는지 확인
(Chrome 기반 브라우저에서 주로 동작)
*/
if ('webkitSpeechRecognition' in window) {

    // 음성 인식 객체 생성
    recognition = new webkitSpeechRecognition();

    // 인식 언어 설정 (한국어)
    recognition.lang = "ko-KR";

    // 연속 인식 모드 (한 문장 끝나도 계속 듣기)
    recognition.continuous = true;

    /*
    🎯 음성이 텍스트로 변환될 때 실행되는 이벤트
    → 핵심 기능
    */
    recognition.onresult = function(event){

        // 결과를 출력할 textarea 가져오기
        let transcriptBox = document.getElementById("transcript");

        // 여러 결과를 순차적으로 추가
        for(let i = event.resultIndex; i < event.results.length; i++){
            transcriptBox.value += event.results[i][0].transcript + " ";
        }
    };

}

/* ============================= */
/* 🎤 녹음 제어 함수 (추가된 기능) */
/* ============================= */

// 녹음 시작
function startRecording(){
    recognition.start();
}

// 녹음 중지
function stopRecording(){
    recognition.stop();
}

/* ============================= */
/* 📌 요약 기능 (기존 기능 수정) */
/* ============================= */

function makeSummary(){

    /*
    🔥 기존 코드:
    meetingText (사용자 입력)

    변경:
    transcript (음성 인식 결과)
    */
    let text = document.getElementById("transcript").value;

    let sentences = text.split(/[.!?]\s/);

    // 앞에서 3문장 추출 (간단 요약 로직)
    let summary = sentences.slice(0,3);

    let result = "<h3>📌 핵심 요약</h3><ul>";

    summary.forEach(s=>{
        result += "<li>"+s+"</li>";
    });

    result += "</ul>";

    document.getElementById("summaryResult").innerHTML = result;

}

</script>

</body>
</html>
```
